# ============================================================
#  Wonder Worlds — Environment Variables
#  Copy this file to .env and fill in your values
#  NEVER commit .env to git — it contains secrets
# ============================================================

# Server
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:5500

# Database (Windows local example)
DATABASE_URL=postgresql://ww_user:ww_password@localhost:5432/wonderworlds

# JWT Secret — generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_64_RANDOM_CHARACTERS

# Stripe (optional — leave as-is to disable payments in dev)
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder
STRIPE_PREMIUM_PRICE_ID=price_placeholder
STRIPE_SCHOOL_PRICE_ID=price_placeholder
