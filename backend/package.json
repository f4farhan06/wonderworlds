{
  "name": "wonderworlds-backend",
  "version": "4.0.0",
  "description": "Wonder Worlds API — Node.js + Express + PostgreSQL",
  "main": "server.js",
  "scripts": {
    "start":     "node server.js",
    "dev":       "nodemon server.js",
    "db:setup":  "psql %DATABASE_URL% -f schema.sql",
    "db:reset":  "psql %DATABASE_URL% -c \"DROP SCHEMA public CASCADE; CREATE SCHEMA public;\" && npm run db:setup"
  },
  "engines": { "node": ">=18.0.0" },
  "dependencies": {
    "bcryptjs":          "^2.4.3",
    "cors":              "^2.8.5",
    "dotenv":            "^16.4.5",
    "express":           "^4.18.3",
    "express-rate-limit":"^7.2.0",
    "helmet":            "^7.1.0",
    "jsonwebtoken":      "^9.0.2",
    "pg":                "^8.11.5",
    "stripe":            "^14.22.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  }
}
